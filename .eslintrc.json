{
  "env": {
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "eqeqeq": ["error", "always"],
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-script-url": "error",
    "no-console": "warn",
    "prefer-const": "warn",
    "no-var": "warn"
  },
  "overrides": [
    {
      "files": ["src/**/*.js"],
      "env": {
        "browser": false,
        "node": false,
        "worker": true,
        "es2022": true
      },
      "globals": {
        "crypto": "readonly",
        "Response": "readonly",
        "Request": "readonly",
        "URL": "readonly",
        "Headers": "readonly",
        "TextEncoder": "readonly",
        "fetch": "readonly"
      }
    },
    {
      "files": ["public/assets/js/**/*.js", "public/admin/**/*.js"],
      "env": {
        "browser": true,
        "es2022": true
      }
    }
  ]
}
