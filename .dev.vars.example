# Cloudflare Email Routing destination.
# Must be a verified destination address in the Cloudflare Email Routing dashboard.
BOOKING_EMAIL_FORWARD_TO=team@example.com

# Optional inbound alias allowlist for the Email Worker.
EMAIL_ROUTING_ALLOWED_LOCAL_PARTS=booking,reservations

# Postmark transactional email configuration for booking lead acknowledgements.
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_API_BASE=https://api.postmarkapp.com

# Sender addresses used for booking lead acknowledgement emails.
BOOKING_FROM_EMAIL=booking@sandboxhotel.com
BOOKING_REPLY_TO_EMAIL=booking@sandboxhotel.com
