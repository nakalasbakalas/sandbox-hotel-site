# Environment variables for local development
# Copy this file to .env and fill in your actual values

# Cloudflare Account Settings
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Site Configuration
SITE_NAME=Sandbox Hotel Site
SITE_URL=https://example.com

# Email / Postmark configuration
# Non-secret vars are set in wrangler.jsonc [vars]. Secrets must be set via:
#   npx wrangler secret put POSTMARK_SERVER_TOKEN
#   npx wrangler secret put BOOKING_EMAIL_FORWARD_TO
#
# POSTMARK_SERVER_TOKEN=               # Postmark server API token (required for outbound email)
# BOOKING_EMAIL_FORWARD_TO=            # Address that receives forwarded inbound booking emails
#
# The following are already set in wrangler.jsonc vars and only need overriding here for local dev:
# BOOKING_FROM_EMAIL=booking@sandboxhotel.com
# BOOKING_REPLY_TO_EMAIL=booking@sandboxhotel.com
# BOOKING_ACK_SUBJECT=Sandbox Hotel booking request received
# POSTMARK_MESSAGE_STREAM=outbound
# POSTMARK_API_BASE=https://api.postmarkapp.com
# EMAIL_ROUTING_ALLOWED_LOCAL_PARTS=booking,reservations
