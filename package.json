{
  "name": "sandbox-hotel-monorepo",
  "version": "1.0.0",
  "description": "Hotel site monorepo - Frontend, API, and Shared utilities",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/web",
    "packages/api",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/web",
    "deploy": "npm run deploy -w packages/web",
    "build": "npm run build -w packages/web",
    "dev:all": "npm run dev --workspaces",
    "test:worker": "node --test src/index.test.js",
    "lint": "eslint src/ public/assets/js/ public/admin/app.js --max-warnings 0",
    "audit:deps": "npm audit --audit-level=high",
    "deploy:cf": "npx wrangler deploy"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@cloudflare/workerd-linux-64": "^1.20260317.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "axe-core": "^4.9.0",
    "jsdom": "^24.0.0"
  }
}
